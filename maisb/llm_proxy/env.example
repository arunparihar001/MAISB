# Copy this to .env for local dev — never commit .env
# On Railway, set these in the Variables tab

# Where to store the SQLite database
# Railway: use /data/usage.db if you have a persistent volume, else leave as default
DB_PATH=usage.db

# Admin key for /admin/* endpoints — change this before deploying
ADMIN_KEY=change_me_in_production

# Optional: HuggingFace token for faster model downloads (avoids rate limits)
# HF_TOKEN=hf_your_token_here

# Public production domains
PUBLIC_BASE_URL=https://maisb.app
APP_DASHBOARD_URL=https://app.maisb.app
API_BASE_URL=https://api.maisb.app
CERTIFY_BASE_URL=https://api.maisb.app

# Resend email notifications
RESEND_API_KEY=re_xxxxx
RESEND_FROM=MAISB <noreply@maisb.app>
RESEND_REPLY_TO=support@maisb.app
SALES_NOTIFY_EMAIL=sales@maisb.app
SECURITY_NOTIFY_EMAIL=security@maisb.app

# Paddle billing (Merchant of Record)
PADDLE_ENV=sandbox
PADDLE_API_KEY=pdl_xxxxx
PADDLE_WEBHOOK_SECRET=pdlwhsec_xxxxx
PADDLE_PRO_PRICE_ID=pri_xxxxx
PADDLE_CERTIFY_PRICE_ID=pri_xxxxx
