PUBLIC_BASE_URL=https://maisb.app
APP_DASHBOARD_URL=https://app.maisb.app
API_BASE_URL=https://api.maisb.app
CERTIFY_BASE_URL=https://api.maisb.app

# Resend email notifications
RESEND_API_KEY=re_xxxxx
RESEND_FROM=MAISB <hello@updates.maisb.app>
RESEND_REPLY_TO=sales@maisb.app
SALES_NOTIFY_EMAIL=sales@maisb.app
SECURITY_NOTIFY_EMAIL=security@maisb.app
# Optional extra comma-separated recipients
RESEND_NOTIFY_EMAILS=

# Paddle billing
PADDLE_ENV=sandbox
PADDLE_API_KEY=pdl_xxxxx
PADDLE_WEBHOOK_SECRET=pdlwhsec_xxxxx
PADDLE_PRO_PRICE_ID=pri_xxxxx
PADDLE_CERTIFY_PRICE_ID=pri_xxxxx
# Optional legacy checkout URL fallback if you use a static hosted Paddle checkout link
PADDLE_CHECKOUT_URL=
